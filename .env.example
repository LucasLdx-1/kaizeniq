# ============================================================
# KaizenIQ — environment configuration
# Copy to backend/.env and fill in for live mode.
# NEVER commit the real .env file (already in .gitignore).
# ============================================================

# "mock" (default, fully offline) | "local" (real Foundry model on-device via
# Foundry Local) | "live" (real Azure Foundry IQ)
FOUNDRY_MODE=mock

# ---- Foundry Local (when FOUNDRY_MODE=local) ----
# Requires Foundry Local installed and a model running:
#   winget install Microsoft.FoundryLocal
#   foundry model run phi-3.5-mini
# The SDK discovers the endpoint automatically; set this only to override.
FOUNDRY_LOCAL_MODEL=phi-3.5-mini
# FOUNDRY_LOCAL_ENDPOINT=http://127.0.0.1:PORT/v1   # optional manual override

# ---- Azure AI Search (from the IQ Series Deploy-to-Azure outputs) ----
SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
SEARCH_INDEX_NAME=kaizeniq-iso-index
KNOWLEDGE_SOURCE_NAME=kaizeniq-iso-processes
KNOWLEDGE_BASE_NAME=kaizeniq-kb

# ---- Azure OpenAI (answer synthesis model for the knowledge base) ----
AOAI_ENDPOINT=https://<your-aoai-resource>.openai.azure.com
AOAI_GPT_DEPLOYMENT=gpt-4o-mini
AOAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ---- Microsoft Foundry project (optional, for Agent Service) ----
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-4o-mini

# ---- API ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
